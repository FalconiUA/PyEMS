# PyEMS controller-clock helper — apply timezone and NTP policy settings.
# install.sh generates this with the real checkout and service-user paths.
[Unit]
Description=PyEMS apply controller time settings

[Service]
Type=oneshot
User=root
ExecStart=/home/pi/PyEMS/.venv/bin/pyems-time-helper --state /home/pi/PyEMS/logs/time-settings.json --status /home/pi/PyEMS/logs/time-sync-status.json --apply
